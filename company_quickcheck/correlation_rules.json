      "field_weights": {
        "name": 0.40,
        "street": 0.30,
        "city": 0.20,
        "plz": 0.10
      },
      "city_aliases": {
        "mnk": "münchendorf",
        "vienna": "wien",
        "klagenfurt": "klagenfurt",
        "salzburg": "salzburg",
        "innsbruck": "innsbruck",
        "graz": "graz",
        "linz": "linz"
      },
      "street_abbreviations": {
        "str.": "strasse",
        "str": "strasse",
        "g.": "gasse",
        "wg": "weg",
        "pl.": "platz",
        "av.": "allee"
      },
      "confidence_threshold": 0.70,
      "lifecycle": {
        "state": "proposal"
      },
      "learned_from": "general-company-lookup-accuracy-improvement",
      "usage_count": 0,
      "notes": "Austrian legal form handling — strip AG/GmbH/etc. before name comparison to focus on distinctive name part. Confidence 0.70 (proposal) — calibrate against known matches before promoting."
    },
    {
