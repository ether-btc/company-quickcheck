{
  "$schema": "./docs/schema.md",
  "version": "1.0.0",
  "description": "AT-specific correlation rules for company-quickcheck correlation-enhanced matching. All rules start as 'proposal' with confidence 0.70 — calibrate against 1,711-row dataset before promoting.",
  "rules": [
    {
      "id": "cr-at-001",
      "created": "2026-05-11T00:00:00Z",
      "trigger_context": "at-company-fuzzy-match",
      "trigger_keywords": [
